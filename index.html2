    <!-- Project Detail Modal -->
    <div id="modal-container" class="fixed inset-0 z-[100] hidden items-center justify-center p-6">
        <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-md" onclick="closeModal()"></div>
        <div class="relative bg-white w-full max-w-3xl max-h-[90vh] rounded-[2.5rem] overflow-y-auto shadow-2xl transition-all scale-95 opacity-0 duration-300" id="modal-content">
            <button class="absolute top-6 right-6 p-3 bg-slate-100 hover:bg-slate-200 rounded-full transition z-10" onclick="closeModal()">
                <i data-lucide="x" class="w-5 h-5 text-slate-600"></i>
            </button>
            <div id="modal-body">
                <!-- Content Injected via JS -->
            </div>
        </div>
    </div>

    <script>
        // Lucide 아이콘 초기화
        lucide.createIcons();

        // 스크롤 시 네비게이션 효과
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('main-nav');
            if (window.scrollY > 50) {
                nav.classList.add('bg-slate-900/90', 'py-3');
                nav.classList.remove('py-4');
            } else {
                nav.classList.remove('bg-slate-900/90', 'py-3');
                nav.classList.add('py-4');
            }
            reveal();
        });

        // 스크롤 등장 애니메이션 (Reveal)
        function reveal() {
            const reveals = document.querySelectorAll(".reveal");
            for (let i = 0; i < reveals.length; i++) {
                const windowHeight = window.innerHeight;
                const elementTop = reveals[i].getBoundingClientRect().top;
                const elementVisible = 150;
                if (elementTop < windowHeight - elementVisible) {
                    reveals[i].classList.add("active");
                }
            }
        }
        window.onload = reveal;

        // 모달 데이터
        const projectData = {
            p1: {
                title: "Luna: 개인 맞춤형 AI 라이프 가이드",
                category: "AI B2C Service",
                image: "https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&q=80&w=1000",
                description: "이 프로젝트는 사용자의 생활 패턴을 학습하여 최적의 제안을 해주는 B2C 모바일 서비스입니다. Azure OpenAI의 GPT-4 모델을 핵심 엔진으로 사용하며, 사용자의 이전 대화 맥락과 취향을 CosmosDB에 저장하여 장기 기억을 구현했습니다.",
                results: [
                    "출시 3개월 만에 사용자 수 5만 명 돌파",
                    "Azure Functions를 활용한 서버리스 아키텍처로 운영 비용 40% 절감",
                    "RAG 패턴 도입을 통한 정보 신뢰성 강화"
                ],
                tech: ["Azure OpenAI", "CosmosDB", "Azure Functions", "React Native", "Vector Search"]
            },
            p2: {
                title: "실시간 AI 쇼핑 비주얼 분석 엔진",
                category: "Cloud Data & AI",
                image: "https://images.unsplash.com/photo-1551288049-bbda64626744?auto=format&fit=crop&q=80&w=1000",
                description: "사용자가 사진을 찍으면 이미지 속 상품의 카테고리, 스타일, 브랜드를 자동 분석하여 검색 결과로 매칭해주는 AI 엔진입니다. Azure Cognitive Services의 Computer Vision API를 커스텀 학습하여 정확도를 높였습니다.",
                results: [
                    "평균 분석 속도 1.2초 미만 달성",
                    "이미지 기반 검색 전환율 15% 상승",
                    "Azure App Service를 통한 안정적인 글로벌 트래픽 처리"
                ],
                tech: ["Azure Computer Vision", "Python", "FastAPI", "App Service", "Azure SQL"]
            }
        };

        // 모달 열기 함수
        function openProjectModal(id) {
            const data = projectData[id];
            const modalBody = document.getElementById('modal-body');
            const container = document.getElementById('modal-container');
            const content = document.getElementById('modal-content');

            modalBody.innerHTML = `
                <div class="relative h-64 sm:h-80 overflow-hidden">
                    <img src="${data.image}" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-white to-transparent"></div>
                </div>
                <div class="p-8 sm:p-12 -mt-20 relative z-10">
                    <span class="text-blue-600 font-bold text-xs uppercase tracking-widest">${data.category}</span>
                    <h3 class="text-3xl sm:text-4xl font-bold mt-2 mb-6">${data.title}</h3>
                    
                    <div class="grid md:grid-cols-3 gap-8 mb-8">
                        <div class="md:col-span-2">
                            <h4 class="font-bold text-slate-900 mb-2">프로젝트 개요</h4>
                            <p class="text-slate-600 text-sm leading-relaxed mb-6">${data.description}</p>
                            
                            <h4 class="font-bold text-slate-900 mb-3">주요 성과</h4>
                            <ul class="space-y-2 mb-6">
                                ${data.results.map(r => `<li class="flex items-start text-sm text-slate-600"><i data-lucide="award" class="w-4 h-4 mr-2 text-yellow-500 flex-shrink-0 mt-0.5"></i> ${r}</li>`).join('')}
                            </ul>
                        </div>
                        <div>
                            <h4 class="font-bold text-slate-900 mb-4">사용 기술</h4>
                            <div class="flex flex-wrap gap-2">
                                ${data.tech.map(t => `<span class="px-3 py-1 bg-blue-50 text-blue-600 text-[10px] rounded-full font-bold uppercase">${t}</span>`).join('')}
                            </div>
                        </div>
                    </div>
                    
                    <div class="flex space-x-4 pt-6 border-t border-slate-100">
                        <button class="px-6 py-3 bg-blue-600 text-white rounded-xl font-bold text-sm hover:bg-blue-500 transition">GitHub 보기</button>
                        <button class="px-6 py-3 bg-slate-100 text-slate-600 rounded-xl font-bold text-sm hover:bg-slate-200 transition">라이브 데모</button>
                    </div>
                </div>
            `;
            
            container.classList.remove('hidden');
            container.classList.add('flex');
            document.body.style.overflow = 'hidden';
            setTimeout(() => {
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            }, 10);
            lucide.createIcons();
        }

        // 모달 닫기 함수
        function closeModal() {
            const container = document.getElementById('modal-container');
            const content = document.getElementById('modal-content');
            content.classList.add('scale-95', 'opacity-0');
            content.classList.remove('scale-100', 'opacity-100');
            setTimeout(() => {
                container.classList.add('hidden');
                container.classList.remove('flex');
                document.body.style.overflow = 'auto';
            }, 300);
        }

        // 모바일 메뉴 버튼 (기능 추가용 자리)
        document.getElementById('mobile-menu-btn').addEventListener('click', () => {
            alert('모바일 메뉴 기능은 현재 준비 중입니다. 섹션 이동을 사용해 주세요!');
        });
    </script>
</body>
</html>
